---
// Call to action component
import { withBasePath } from '../consts';
---

<section class="py-20">
	<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center rounded-3xl border border-cyan-300/20 bg-gradient-to-r from-cyan-600/30 to-blue-600/30 py-14">
		<h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
			Ready to Transform Your Infrastructure?
		</h2>
		<p class="text-xl text-cyan-100 mb-8">
			Let's discuss how we can optimize your cloud infrastructure, automate deployments, and scale your applications with modern DevOps practices.
		</p>
		<div class="flex flex-col sm:flex-row gap-4 justify-center">
			<a href={withBasePath('/contact')} class="rounded-xl bg-cyan-400 text-gray-950 hover:bg-cyan-300 px-8 py-3 font-semibold transition-colors">
				Start a Conversation
			</a>
			<a href={withBasePath('/blog')} class="rounded-xl border border-white/40 text-white hover:bg-white/10 px-8 py-3 font-semibold transition-colors">
				Read My Blog
			</a>
		</div>
	</div>
</section>