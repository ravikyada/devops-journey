---
import { getCollection } from 'astro:content';
import { withBasePath } from '../consts';

const posts = await getCollection('blog');
const featuredPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()).slice(0, 3);
---

<section class="py-20 bg-gray-900">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center mb-12">
			<h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Latest Blog Posts</h2>
			<p class="text-gray-400 text-lg">Insights and tutorials on DevOps, cloud, and automation</p>
		</div>
		<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
			{featuredPosts.map((post) => (
				<article class="overflow-hidden rounded-2xl border border-white/10 bg-gray-800/70 hover:border-cyan-400/50 transition-colors">
					{post.data.heroImage && (
						<img src={post.data.heroImage.src} alt={post.data.heroImage.alt || post.data.title} class="w-full h-48 object-cover" />
					)}
					<div class="p-6">
						<h3 class="text-xl font-semibold text-white mb-2">
							<a href={withBasePath(`/blog/${post.slug}`)} class="hover:text-cyan-400 transition-colors">{post.data.title}</a>
						</h3>
						<p class="text-gray-400 mb-4">{post.data.description}</p>
						<div class="flex items-center text-sm text-gray-500">
							<time datetime={post.data.pubDate.toISOString()}>
								{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
							</time>
						</div>
					</div>
				</article>
			))}
		</div>
		<div class="text-center mt-12">
			<a href={withBasePath('/blog')} class="rounded-xl bg-cyan-500 hover:bg-cyan-400 text-gray-950 px-8 py-3 font-semibold transition-colors">
				View All Posts
			</a>
		</div>
	</div>
</section>