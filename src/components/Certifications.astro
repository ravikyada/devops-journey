---
// Certifications component
---

<section class="py-20 bg-gray-800">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center mb-12">
			<h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Certifications</h2>
			<p class="text-gray-400 text-lg">Professional certifications validating my expertise</p>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			<div class="bg-gray-700 rounded-lg p-6 text-center hover:bg-gray-600 transition-colors">
				<div class="w-16 h-16 bg-orange-500 rounded-lg flex items-center justify-center mx-auto mb-4">
					<span class="text-white font-bold text-lg">AWS</span>
				</div>
				<h3 class="text-lg font-semibold text-white mb-2">AWS Solutions Architect Professional</h3>
				<p class="text-gray-400 text-sm">Amazon Web Services • 2023</p>
			</div>
			<div class="bg-gray-700 rounded-lg p-6 text-center hover:bg-gray-600 transition-colors">
				<div class="w-16 h-16 bg-blue-500 rounded-lg flex items-center justify-center mx-auto mb-4">
					<span class="text-white font-bold text-lg">CKA</span>
				</div>
				<h3 class="text-lg font-semibold text-white mb-2">Certified Kubernetes Administrator</h3>
				<p class="text-gray-400 text-sm">Cloud Native Computing Foundation • 2022</p>
			</div>
			<div class="bg-gray-700 rounded-lg p-6 text-center hover:bg-gray-600 transition-colors">
				<div class="w-16 h-16 bg-purple-500 rounded-lg flex items-center justify-center mx-auto mb-4">
					<span class="text-white font-bold text-lg">TFC</span>
				</div>
				<h3 class="text-lg font-semibold text-white mb-2">Terraform Certified Associate</h3>
				<p class="text-gray-400 text-sm">HashiCorp • 2021</p>
			</div>
		</div>
	</div>
</section>