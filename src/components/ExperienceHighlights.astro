---
// Experience highlights component
import { withBasePath } from '../consts';
---

<section class="py-20 bg-gray-900">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center mb-12">
			<h2 class="text-3xl md:text-4xl font-bold text-white mb-4">Experience Highlights</h2>
			<p class="text-gray-400 text-lg">Key achievements and roles in my DevOps career</p>
		</div>
		<div class="grid md:grid-cols-2 gap-8">
			<div class="rounded-2xl border border-white/10 bg-gray-800 p-6">
				<div class="flex items-center mb-4">
					<div class="w-12 h-12 bg-cyan-600 rounded-lg flex items-center justify-center mr-4">
						<span class="text-white font-bold text-xl">Sr</span>
					</div>
					<div>
						<h3 class="text-xl font-semibold text-white">Senior DevOps Engineer</h3>
						<p class="text-cyan-400">TechCorp Inc. • 2022 - Present</p>
					</div>
				</div>
				<ul class="text-gray-300 space-y-2">
					<li>• Architected and deployed Kubernetes clusters serving 1M+ users</li>
					<li>• Reduced deployment time by 80% using GitLab CI/CD pipelines</li>
					<li>• Implemented infrastructure as code with Terraform across 50+ services</li>
					<li>• Led migration to AWS EKS with Karpenter for cost optimization</li>
				</ul>
			</div>
			<div class="rounded-2xl border border-white/10 bg-gray-800 p-6">
				<div class="flex items-center mb-4">
					<div class="w-12 h-12 bg-blue-600 rounded-lg flex items-center justify-center mr-4">
						<span class="text-white font-bold text-xl">Dev</span>
					</div>
					<div>
						<h3 class="text-xl font-semibold text-white">DevOps Engineer</h3>
						<p class="text-cyan-400">CloudTech Solutions • 2020 - 2022</p>
					</div>
				</div>
				<ul class="text-gray-300 space-y-2">
					<li>• Built automated monitoring stack with Prometheus and Grafana</li>
					<li>• Containerized 30+ applications using Docker and Kubernetes</li>
					<li>• Implemented blue-green deployments reducing downtime by 95%</li>
					<li>• Mentored junior engineers on cloud best practices</li>
				</ul>
			</div>
		</div>
		<div class="text-center mt-12">
			<a href={withBasePath('/experience')} class="rounded-xl bg-cyan-500 hover:bg-cyan-400 text-gray-950 px-8 py-3 font-semibold transition-colors">
				View Full Experience
			</a>
		</div>
	</div>
</section>