---
// Hero section component
import { withBasePath } from '../consts';
---

<section class="relative py-24">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center rounded-3xl border border-white/10 bg-gradient-to-br from-gray-900 via-slate-900 to-gray-800 px-6 py-16 shadow-2xl shadow-cyan-900/20">
			<p class="mb-4 text-sm uppercase tracking-[0.2em] text-cyan-300">DevOps Portfolio</p>
			<h1 class="text-4xl md:text-6xl font-bold text-white mb-6 tracking-tight">
				Senior DevOps Engineer
			</h1>
			<p class="text-xl md:text-2xl text-gray-300 mb-8 max-w-3xl mx-auto">
				Specializing in AWS, Kubernetes, Terraform, Docker, and CI/CD. Building scalable cloud infrastructure and automating deployments for modern applications.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href={withBasePath('/projects')} class="rounded-xl bg-cyan-500 hover:bg-cyan-400 text-gray-950 px-8 py-3 font-semibold transition-colors">
					View My Work
				</a>
				<a href={withBasePath('/contact')} class="rounded-xl border border-white/20 text-gray-100 hover:bg-white/10 px-8 py-3 font-semibold transition-colors">
					Get In Touch
				</a>
			</div>
		</div>
	</div>
	<!-- Animated background elements -->
	<div class="absolute inset-0 overflow-hidden pointer-events-none">
		<div class="absolute -top-40 -right-40 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl animate-pulse"></div>
		<div class="absolute -bottom-40 -left-40 w-80 h-80 bg-blue-500/10 rounded-full blur-3xl animate-pulse delay-1000"></div>
	</div>
</section>