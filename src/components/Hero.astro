---
// Hero section component
import { withBasePath } from '../consts';
---

<section class="relative py-14 sm:py-20 lg:py-24">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="text-center rounded-3xl border border-cyan-300/20 bg-slate-900/90 px-5 py-12 sm:px-8 sm:py-14 shadow-2xl shadow-cyan-950/30 backdrop-blur-sm">
			<p class="mb-4 text-xs sm:text-sm uppercase tracking-[0.2em] text-cyan-300">DevOps Portfolio</p>
			<h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-5 sm:mb-6 tracking-tight leading-tight">
				Senior DevOps Engineer
			</h1>
			<p class="text-base sm:text-lg md:text-xl text-gray-200 mb-8 max-w-3xl mx-auto">
				Specializing in AWS, Kubernetes, Terraform, Docker, and CI/CD. Building scalable cloud infrastructure and automating deployments for modern applications.
			</p>
			<div class="flex flex-col sm:flex-row gap-3 sm:gap-4 justify-center">
				<a href={withBasePath('/projects')} class="rounded-xl bg-cyan-400 hover:bg-cyan-300 text-gray-950 px-6 sm:px-8 py-3 font-semibold transition-colors">
					View My Work
				</a>
				<a href={withBasePath('/contact')} class="rounded-xl border border-white/30 text-gray-100 hover:bg-white/10 px-6 sm:px-8 py-3 font-semibold transition-colors">
					Get In Touch
				</a>
			</div>
		</div>
	</div>
	<!-- Animated background elements -->
	<div class="absolute inset-0 overflow-hidden pointer-events-none">
		<div class="absolute -top-40 -right-40 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl animate-pulse"></div>
		<div class="absolute -bottom-40 -left-40 w-80 h-80 bg-blue-500/10 rounded-full blur-3xl animate-pulse delay-1000"></div>
	</div>
</section>