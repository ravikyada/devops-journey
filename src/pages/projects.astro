---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-gray-900 text-gray-100 min-h-screen">
		<Header />
		<main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
			<div class="mb-12">
				<h1 class="text-4xl md:text-5xl font-bold text-white mb-6">Projects & Open Source</h1>
				<div class="w-24 h-1 bg-cyan-500 mb-8"></div>
				<p class="text-gray-300 text-lg max-w-3xl">
					A collection of projects I've worked on, ranging from infrastructure automation tools to monitoring solutions and cloud architectures.
				</p>
			</div>

			<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
				<div class="bg-gray-800 rounded-lg overflow-hidden hover:bg-gray-700 transition-colors">
					<div class="h-48 bg-gradient-to-br from-orange-500 to-red-600 flex items-center justify-center">
						<span class="text-white text-4xl">🚀</span>
					</div>
					<div class="p-6">
						<h3 class="text-xl font-semibold text-white mb-2">terraform-aws-eks</h3>
						<p class="text-gray-300 mb-4">Complete Terraform module for deploying production-ready EKS clusters with Karpenter, ALB, and comprehensive security configurations.</p>
						<div class="flex flex-wrap gap-2 mb-4">
							<span class="bg-blue-600 text-white text-xs px-2 py-1 rounded">Terraform</span>
							<span class="bg-green-600 text-white text-xs px-2 py-1 rounded">AWS</span>
							<span class="bg-purple-600 text-white text-xs px-2 py-1 rounded">Kubernetes</span>
						</div>
						<div class="flex items-center justify-between">
							<div class="flex space-x-4 text-sm text-gray-400">
								<span>⭐ 127</span>
								<span>🍴 34</span>
							</div>
							<a href="https://github.com/ravikyada/terraform-aws-eks" class="text-cyan-400 hover:text-cyan-300 text-sm">View →</a>
						</div>
					</div>
				</div>

				<div class="bg-gray-800 rounded-lg overflow-hidden hover:bg-gray-700 transition-colors">
					<div class="h-48 bg-gradient-to-br from-blue-500 to-cyan-600 flex items-center justify-center">
						<span class="text-white text-4xl">📊</span>
					</div>
					<div class="p-6">
						<h3 class="text-xl font-semibold text-white mb-2">k8s-monitoring-stack</h3>
						<p class="text-gray-300 mb-4">Production-ready monitoring stack for Kubernetes using Prometheus, Grafana, Loki, and AlertManager with automated deployment.</p>
						<div class="flex flex-wrap gap-2 mb-4">
							<span class="bg-yellow-600 text-white text-xs px-2 py-1 rounded">Helm</span>
							<span class="bg-blue-600 text-white text-xs px-2 py-1 rounded">Prometheus</span>
							<span class="bg-green-600 text-white text-xs px-2 py-1 rounded">Grafana</span>
						</div>
						<div class="flex items-center justify-between">
							<div class="flex space-x-4 text-sm text-gray-400">
								<span>⭐ 89</span>
								<span>🍴 21</span>
							</div>
							<a href="https://github.com/ravikyada/k8s-monitoring-stack" class="text-cyan-400 hover:text-cyan-300 text-sm">View →</a>
						</div>
					</div>
				</div>

				<div class="bg-gray-800 rounded-lg overflow-hidden hover:bg-gray-700 transition-colors">
					<div class="h-48 bg-gradient-to-br from-purple-500 to-pink-600 flex items-center justify-center">
						<span class="text-white text-4xl">🔄</span>
					</div>
					<div class="p-6">
						<h3 class="text-xl font-semibold text-white mb-2">ci-cd-pipelines</h3>
						<p class="text-gray-300 mb-4">Reusable GitLab CI/CD pipeline templates for multi-stage deployments, testing, and security scanning across different technologies.</p>
						<div class="flex flex-wrap gap-2 mb-4">
							<span class="bg-orange-600 text-white text-xs px-2 py-1 rounded">GitLab CI</span>
							<span class="bg-blue-600 text-white text-xs px-2 py-1 rounded">Docker</span>
							<span class="bg-red-600 text-white text-xs px-2 py-1 rounded">Security</span>
						</div>
						<div class="flex items-center justify-between">
							<div class="flex space-x-4 text-sm text-gray-400">
								<span>⭐ 56</span>
								<span>🍴 18</span>
							</div>
							<a href="https://github.com/ravikyada/ci-cd-pipelines" class="text-cyan-400 hover:text-cyan-300 text-sm">View →</a>
						</div>
					</div>
				</div>

				<div class="bg-gray-800 rounded-lg overflow-hidden hover:bg-gray-700 transition-colors">
					<div class="h-48 bg-gradient-to-br from-green-500 to-teal-600 flex items-center justify-center">
						<span class="text-white text-4xl">⚡</span>
					</div>
					<div class="p-6">
						<h3 class="text-xl font-semibold text-white mb-2">aws-cost-optimizer</h3>
						<p class="text-gray-300 mb-4">Python-based tool for analyzing and optimizing AWS costs with recommendations for EC2, RDS, and Lambda resource optimization.</p>
						<div class="flex flex-wrap gap-2 mb-4">
							<span class="bg-yellow-600 text-white text-xs px-2 py-1 rounded">Python</span>
							<span class="bg-orange-600 text-white text-xs px-2 py-1 rounded">AWS</span>
							<span class="bg-green-600 text-white text-xs px-2 py-1 rounded">Cost Optimization</span>
						</div>
						<div class="flex items-center justify-between">
							<div class="flex space-x-4 text-sm text-gray-400">
								<span>⭐ 43</span>
								<span>🍴 12</span>
							</div>
							<a href="https://github.com/ravikyada/aws-cost-optimizer" class="text-cyan-400 hover:text-cyan-300 text-sm">View →</a>
						</div>
					</div>
				</div>

				<div class="bg-gray-800 rounded-lg overflow-hidden hover:bg-gray-700 transition-colors">
					<div class="h-48 bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center">
						<span class="text-white text-4xl">🔒</span>
					</div>
					<div class="p-6">
						<h3 class="text-xl font-semibold text-white mb-2">terraform-aws-security</h3>
						<p class="text-gray-300 mb-4">Comprehensive security module for AWS infrastructure including VPC, security groups, IAM roles, and compliance configurations.</p>
						<div class="flex flex-wrap gap-2 mb-4">
							<span class="bg-blue-600 text-white text-xs px-2 py-1 rounded">Terraform</span>
							<span class="bg-red-600 text-white text-xs px-2 py-1 rounded">Security</span>
							<span class="bg-green-600 text-white text-xs px-2 py-1 rounded">AWS</span>
						</div>
						<div class="flex items-center justify-between">
							<div class="flex space-x-4 text-sm text-gray-400">
								<span>⭐ 78</span>
								<span>🍴 25</span>
							</div>
							<a href="https://github.com/ravikyada/terraform-aws-security" class="text-cyan-400 hover:text-cyan-300 text-sm">View →</a>
						</div>
					</div>
				</div>

				<div class="bg-gray-800 rounded-lg overflow-hidden hover:bg-gray-700 transition-colors">
					<div class="h-48 bg-gradient-to-br from-cyan-500 to-blue-600 flex items-center justify-center">
						<span class="text-white text-4xl">📈</span>
					</div>
					<div class="p-6">
						<h3 class="text-xl font-semibold text-white mb-2">infrastructure-dashboard</h3>
						<p class="text-gray-300 mb-4">Real-time infrastructure monitoring dashboard built with React and connected to Prometheus metrics for comprehensive system visibility.</p>
						<div class="flex flex-wrap gap-2 mb-4">
							<span class="bg-blue-600 text-white text-xs px-2 py-1 rounded">React</span>
							<span class="bg-green-600 text-white text-xs px-2 py-1 rounded">Prometheus</span>
							<span class="bg-yellow-600 text-white text-xs px-2 py-1 rounded">TypeScript</span>
						</div>
						<div class="flex items-center justify-between">
							<div class="flex space-x-4 text-sm text-gray-400">
								<span>⭐ 31</span>
								<span>🍴 9</span>
							</div>
							<a href="https://github.com/ravikyada/infrastructure-dashboard" class="text-cyan-400 hover:text-cyan-300 text-sm">View →</a>
						</div>
					</div>
				</div>
			</div>

			<section class="text-center">
				<h2 class="text-3xl font-bold text-white mb-4">More on GitHub</h2>
				<p class="text-gray-300 mb-8">Check out my complete portfolio of projects and contributions</p>
				<a href="https://github.com/ravikyada" class="bg-cyan-600 hover:bg-cyan-700 text-white px-8 py-3 rounded-lg font-semibold transition-colors inline-flex items-center">
					<svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
						<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
					</svg>
					View GitHub Profile
				</a>
			</section>
		</main>
		<Footer />
	</body>
</html>