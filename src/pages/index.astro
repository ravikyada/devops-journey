---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TechStack from '../components/TechStack.astro';
import FeaturedBlogs from '../components/FeaturedBlogs.astro';
import FeaturedRepos from '../components/FeaturedRepos.astro';
import ExperienceHighlights from '../components/ExperienceHighlights.astro';
import Certifications from '../components/Certifications.astro';
import CTA from '../components/CTA.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-gray-900 text-gray-100 min-h-screen">
		<Header />
		<main class="space-y-20">
			<Hero />
			<TechStack />
			<FeaturedBlogs />
			<FeaturedRepos />
			<ExperienceHighlights />
			<Certifications />
			<CTA />
		</main>
		<Footer />
	</body>
</html>
