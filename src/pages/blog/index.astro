---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE, withBasePath } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPosts = posts.filter((post) => post.data.featured).slice(0, 2);
const recentPosts = featuredPosts.length > 0 ? posts.filter((post) => !post.data.featured) : posts;
const topPosts = featuredPosts.length > 0 ? featuredPosts : posts.slice(0, 2);

const tagCounts = posts.reduce<Record<string, number>>((map, post) => {
	(post.data.tags || []).forEach((tag) => {
		map[tag] = (map[tag] || 0) + 1;
	});
	return map;
}, {});

const tagList = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-slate-950 text-slate-100">
		<Header />
		<main class="max-w-7xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
			<section class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_320px]">
				<div class="space-y-10">
					<div class="rounded-[2rem] border border-white/10 bg-slate-900/90 p-8 shadow-2xl shadow-slate-950/30">
						<p class="text-sm uppercase tracking-[0.3em] text-cyan-300">Writing</p>
						<h1 class="mt-4 text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
						Blog posts, tutorials, and DevOps insights
						</h1>
						<p class="mt-4 max-w-2xl text-slate-300 sm:text-lg">
						Latest guides and stories on cloud infrastructure, Kubernetes, CI/CD, and modern DevOps practices.
						</p>
					</div>

					<div class="grid gap-6">
						<h2 class="text-2xl font-semibold text-white">Featured posts</h2>
						<div class="grid gap-6 xl:grid-cols-2">
							{topPosts.map((post) => (
								<article class="overflow-hidden rounded-[1.75rem] border border-white/10 bg-slate-900/95 transition duration-300 hover:border-cyan-400/50 hover:bg-slate-900 shadow-lg shadow-slate-950/25">
									<a href={withBasePath(`/blog/${post.slug}/`)} class="block">
										{post.data.heroImage && (
											<Image
												width={960}
												height={460}
												src={post.data.heroImage}
												alt={post.data.title}
												class="h-56 w-full object-cover"
											/>
										)}
										<div class="p-6">
											<p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-300">{post.data.tags?.[0] ?? 'DevOps'}</p>
											<h3 class="mt-3 text-2xl font-semibold text-white">{post.data.title}</h3>
											<p class="mt-4 text-slate-300 line-clamp-3">{post.data.description}</p>
											<div class="mt-6 flex flex-wrap gap-3 text-sm text-slate-400">
												<time>{new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
												{post.data.tags?.map((tag) => (
													<span key={tag} class="rounded-full border border-slate-700 px-3 py-1 text-xs uppercase tracking-[0.18em] text-slate-300">{tag}</span>
												))}
											</div>
										</div>
									</a>
								</article>
							))}
						</div>
					</div>

					<div class="space-y-6">
						<h2 class="text-2xl font-semibold text-white">All posts</h2>
						<div class="grid gap-6">
							{recentPosts.map((post) => (
								<article class="rounded-[1.5rem] border border-white/10 bg-slate-900/90 p-6 transition hover:border-cyan-400/40 hover:bg-slate-900 shadow-slate-950/20">
									<a href={withBasePath(`/blog/${post.slug}/`)} class="group block">
										<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
											<h3 class="text-xl font-semibold text-white group-hover:text-cyan-300">{post.data.title}</h3>
											<time class="text-sm text-slate-400">{new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
										</div>
										<p class="mt-3 text-slate-300">{post.data.description}</p>
										<div class="mt-4 flex flex-wrap gap-2">
											{post.data.tags?.map((tag) => (
												<span key={tag} class="rounded-full bg-slate-800 px-3 py-1 text-xs uppercase tracking-[0.18em] text-slate-300">{tag}</span>
											))}
										</div>
									</a>
								</article>
							))}
						</div>
					</div>
				</div>

				<aside class="space-y-8">
					<div class="rounded-[2rem] border border-white/10 bg-slate-900/95 p-6 shadow-2xl shadow-slate-950/20">
						<h2 class="text-xl font-semibold text-white">About this blog</h2>
						<p class="mt-4 text-slate-300">
							A minimal DevOps blog with a focus on actionable tutorials, cloud-native best practices, and tooling guides.
						</p>
						<div class="mt-6 space-y-3 text-sm text-slate-400">
							<p><span class="font-semibold text-slate-100">Posts:</span> {posts.length}</p>
							<p><span class="font-semibold text-slate-100">Topics:</span> {tagList.length}</p>
							<p><span class="font-semibold text-slate-100">Built with:</span> Astro & Tailwind CSS</p>
						</div>
					</div>

					<div class="rounded-[2rem] border border-white/10 bg-slate-900/95 p-6 shadow-2xl shadow-slate-950/20">
						<h2 class="text-xl font-semibold text-white">Popular tags</h2>
						<div class="mt-5 flex flex-wrap gap-3">
							{tagList.map(([tag, count]) => (
								<span key={tag} class="rounded-full border border-slate-700 bg-slate-950/70 px-3 py-2 text-sm text-slate-300">{tag} ({count})</span>
							))}
						</div>
					</div>
				</aside>
			</section>
		</main>
		<Footer />
	</body>
</html>
